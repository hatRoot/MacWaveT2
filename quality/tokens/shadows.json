{
  "$schema": "./schema.json",
  "name": "MacWave Shadow Tokens",
  "version": "1.0.0",
  "shadows": {
    "ctaHover": {
      "value": "0 6px 20px rgba(0, 0, 0, 0.3)",
      "usage": ".cta-button.primary:hover"
    },
    "modal": {
      "value": "0 25px 50px rgba(0, 0, 0, 0.5)",
      "usage": ".modal-container"
    },
    "neonGreen": {
      "value": "0 0 10px rgba(48, 209, 88, 0.2)",
      "hover": "0 0 20px rgba(48, 209, 88, 0.6)",
      "usage": ".header-cta.neon-green"
    },
    "neonYellow": {
      "value": "0 0 10px rgba(255, 204, 0, 0.2)",
      "hover": "0 0 20px rgba(255, 204, 0, 0.6)",
      "usage": ".header-cta.neon-yellow"
    },
    "neonOrange": {
      "value": "0 0 10px rgba(255, 102, 0, 0.2)",
      "hover": "0 0 200px rgba(255, 102, 0, 0.6)",
      "usage": ".header-cta.neon-orange"
    },
    "pulse": {
      "value": "0 0 0 0 rgba(48, 209, 88, 0.7)",
      "usage": "@keyframes pulse"
    }
  }
}
