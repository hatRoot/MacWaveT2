{
  "$schema": "./schema.json",
  "name": "MacWave Typography Tokens",
  "version": "1.0.0",
  "fontFamily": {
    "base": {
      "value": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\"",
      "cssVar": "--font-family-base",
      "tailwind": "font-sans"
    },
    "brand": {
      "value": "\"Caveat Brush\", cursive",
      "cssVar": null,
      "tailwind": null,
      "usage": "Decoraciones y acentos de marca"
    }
  },
  "fontWeight": {
    "light": { "value": 300, "cssVar": "--font-weight-light", "tailwind": "font-light" },
    "regular": { "value": 400, "cssVar": "--font-weight-regular", "tailwind": "font-regular" },
    "medium": { "value": 500, "cssVar": "--font-weight-medium", "tailwind": "font-medium" },
    "semibold": { "value": 600, "cssVar": "--font-weight-semibold", "tailwind": "font-semibold" },
    "bold": { "value": 700, "cssVar": "--font-weight-bold", "tailwind": "font-bold" }
  },
  "fontSize": {
    "h1": { "value": "3.5em", "tailwind": "text-5xl" },
    "h2": { "value": "2.5em", "tailwind": "text-4xl" },
    "h3": { "value": "1.8em", "tailwind": "text-2xl" },
    "body": { "value": "1em", "tailwind": "text-base" },
    "small": { "value": "0.85em", "tailwind": "text-sm" },
    "nav": { "value": "1.1em", "tailwind": null }
  },
  "lineHeight": {
    "body": { "value": 1.6, "tailwind": "leading-relaxed" },
    "heading": { "value": 1.2, "tailwind": "leading-tight" }
  }
}
